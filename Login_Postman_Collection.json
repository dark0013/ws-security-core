{
  "info": {
    "name": "Login JWT - WS Security Core",
    "description": "Colección para probar el endpoint de login con JWT",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login - Credenciales Válidas",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usernameOrEmail\": \"admin\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5562/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5562",
          "path": ["auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "Login - Usuario por Email",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usernameOrEmail\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5562/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5562",
          "path": ["auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "Login - Credenciales Inválidas (401)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usernameOrEmail\": \"admin\",\n  \"password\": \"wrongpassword\"\n}"
        },
        "url": {
          "raw": "http://localhost:5562/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5562",
          "path": ["auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "Login - Usuario No Existe (401)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usernameOrEmail\": \"nonexistent\",\n  \"password\": \"password123\"\n}"
        },
        "url": {
          "raw": "http://localhost:5562/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5562",
          "path": ["auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "Login - Campos Vacíos (400)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"usernameOrEmail\": \"\",\n  \"password\": \"\"\n}"
        },
        "url": {
          "raw": "http://localhost:5562/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5562",
          "path": ["auth", "login"]
        }
      },
      "response": []
    },
    {
      "name": "Acceder a Endpoint Protegido con JWT",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt_token}}",
            "description": "Reemplazar {{jwt_token}} con el token obtenido del login"
          }
        ],
        "url": {
          "raw": "http://localhost:5562/api/v1/roles",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5562",
          "path": ["api", "v1", "roles"]
        }
      },
      "response": []
    },
    {
      "name": "Acceder sin Token (401)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:5562/api/v1/roles",
          "protocol": "http",
          "host": ["localhost"],
          "port": "5562",
          "path": ["api", "v1", "roles"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "",
      "type": "string"
    }
